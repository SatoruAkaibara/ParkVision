# ─── ParkVision Configuration ────────────────────────────────────────────────
# Edit these values to tune detection behaviour without touching Python code.

# Node.js backend address
SERVER_URL=http://localhost:3001

# Path to the video file (use forward slashes even on Windows)
VIDEO_PATH=D:/Dev/ParkVision/ai-engine/test_video.mp4

# YOLO model weights file
MODEL_PATH=yolo11s.pt

# Detection confidence threshold (0–1). Lower = more detections, more noise.
CONFIDENCE=0.30

# Minimum bounding-box area in pixels. Boxes smaller than this are ignored.
MIN_BOX_AREA=500

# Intersection-over-Union threshold (0–1).
# A spot is "occupied" when a vehicle overlaps it by at least this fraction.
IOU_THRESHOLD=0.30

# HTTP retry settings
HTTP_RETRIES=3
HTTP_BACKOFF_FACTOR=0.5

# Resize every frame to this resolution before inference (width x height).
FRAME_WIDTH=800
FRAME_HEIGHT=600